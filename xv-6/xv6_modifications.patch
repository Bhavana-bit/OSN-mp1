+// compute weight from nice [-20 .. 19] using integer arithmetic.
+// weight = 1024 / (1.25^nice) approx
+static int
+compute_weight(int nice)
+{
+  int n = nice;
+  uint64 numer = 1;
+  uint64 denom = 1;
+  int i;
+
+  if (n == 0) return 1024;
+
+  if (n > 0) {
+    // weight = 1024 * (4^n) / (5^n)
+    for (i = 0; i < n; i++) {
+      numer *= 4;
+      denom *= 5;
+      if (numer > (1ULL<<62)) numer = (1ULL<<62);
+      if (denom > (1ULL<<62)) denom = (1ULL<<62);
+    }
+    uint64 w = (1024ULL * numer) / denom;
+    if (w < 1) w = 1;
+    if (w > INT_MAX) w = INT_MAX;
+    return (int)w;
+  } else {
+    // n < 0: weight = 1024 * (5^(-n)) / (4^(-n))
+    int N = -n;
+    for (i = 0; i < N; i++) {
+      numer *= 5;
+      denom *= 4;
+      if (numer > (1ULL<<62)) numer = (1ULL<<62);
+      if (denom > (1ULL<<62)) denom = (1ULL<<62);
+    }
+    uint64 w = (1024ULL * numer) / denom;
+    if (w < 1) w = 1;
+    if (w > INT_MAX) w = INT_MAX;
+    return (int)w;
+  }
+}
